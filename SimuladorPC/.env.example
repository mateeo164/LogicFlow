# Copia este archivo a .env y ajusta los valores según tu entorno.

# Puerto en el que escucha el servidor Express.
# La mayoría de plataformas de hosting inyectan PORT automáticamente.
PORT=3000

# Entorno de ejecución: development | production
# En "production" el servidor omite los logs de localhost.
NODE_ENV=development

# Clave de API de Google Gemini (https://aistudio.google.com/apikey) para el
# tutor IA conversacional del laboratorio 3D (POST /api/tutor-chat).
# Sin esta variable el endpoint responde 503 y el widget del chat muestra un
# aviso de "no configurado"; el resto del simulador funciona con normalidad.
GEMINI_API_KEY=
